{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/napetrov/skills/schemas/skill-card.schema.json",
  "title": "Portable Skill Card",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "owner",
    "source_url",
    "implementation_url",
    "source",
    "catalog",
    "data_classification",
    "output",
    "deployment_geography",
    "tools",
    "network",
    "scripts",
    "permissions",
    "risks",
    "mitigations",
    "ethical_considerations",
    "release_evidence",
    "signature",
    "verification_status"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://github.com/"
    },
    "implementation_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://github.com/"
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "ref", "path"],
      "properties": {
        "repository": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://github.com/"
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "pattern": "^skills/[a-z0-9]+(?:-[a-z0-9]+)*(?:/[A-Za-z0-9_.-]+)*$"
        }
      }
    },
    "catalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "path"],
      "properties": {
        "repository": {
          "type": "string",
          "const": "https://github.com/napetrov/skills"
        },
        "path": {
          "type": "string",
          "pattern": "^skills/[a-z0-9]+(?:-[a-z0-9]+)*$"
        }
      }
    },
    "data_classification": {
      "type": "string",
      "enum": ["public", "internal", "confidential"]
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "format"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["agent-instructions"]
        },
        "format": {
          "type": "string",
          "enum": ["markdown"]
        }
      }
    },
    "deployment_geography": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "destinations"],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "destinations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "required": {
                "const": false
              }
            }
          },
          "then": {
            "properties": {
              "destinations": {
                "maxItems": 0
              }
            }
          }
        }
      ]
    },
    "scripts": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^scripts/[A-Za-z0-9_.-]+\\.(?:py|sh|js)$"
      },
      "uniqueItems": true
    },
    "permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "risks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "mitigations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "ethical_considerations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "release_evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_manifest", "attestation", "signing_workflow"],
      "properties": {
        "artifact_manifest": {
          "type": "string",
          "const": "skills.lock.json"
        },
        "attestation": {
          "type": "string",
          "enum": ["none", "github-artifact-attestations"]
        },
        "signing_workflow": {
          "type": "string",
          "const": ".github/workflows/release.yml"
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "identity", "subjects"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["unsigned", "github-attested"]
        },
        "identity": {
          "type": "string",
          "minLength": 1
        },
        "subjects": {
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        }
      }
    },
    "verification_status": {
      "type": "string",
      "enum": ["unverified", "smoke-tested", "reviewed", "verified", "deprecated"]
    }
  }
}
